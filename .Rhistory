# warm_cache.R — Run once to populate translation cache for all 5 languages
# Run line by line or source the whole file. Takes ~5-10 minutes.
setwd(dirname(rstudioapi::getSourceEditorContext()$path))
library(httr)
library(dplyr)
library(readr)
library(jsonlite)
# Load the cache file (relative path)
CACHE_FILE <- "translation_cache.rds"
t_cache <- if (file.exists(CACHE_FILE)) readRDS(CACHE_FILE) else list()
# Same translate function as in app.R
translate <- function(text, lang) {
if (lang == "" || is.na(text)) return(text)
if (lang == "en" && !grepl("[^\\x00-\\x7F]", text, perl = TRUE)) return(text)
key <- paste(text, lang)
cached <- t_cache[[key]]
if (!is.null(cached) && is.character(cached) && length(cached) == 1 && !is.na(cached)) return(cached)
tryCatch({
res <- GET("https://translate.googleapis.com/translate_a/single",
query = list(client = "gtx", sl = "auto", tl = lang, dt = "t", q = text))
out <- content(res)[[1]][[1]][[1]]
if (!is.character(out) || length(out) != 1 || is.na(out)) return(text)
t_cache[[key]] <<- out
out
}, error = function(e) text)
}
# ── Load data sources to extract dynamic strings ───────────────────
# IMPORTANT: Update these paths to match your folder structure (Option A vs B from before)
# If you chose Option A (subfolders):
atbats <- read_csv("npb_atbats/atbats_master.csv",
col_types = cols(.default = "c"))
players <- fromJSON("npb_atbats/players.json")
playerinfo <- read_csv("npb_stats/rosters.csv")
SeasonBattingStats <- read_csv("npb_stats/batting_individual.csv")
SeasonPitchingStats <- read_csv("npb_stats/pitching_individual.csv")
# If you chose Option B (flat folder), use these instead:
# atbats <- read_csv("atbats_master.csv", col_types = cols(.default = "c"))
# players <- fromJSON("players.json")
# playerinfo <- read_csv("rosters.csv")
# SeasonBattingStats <- read_csv("batting_individual.csv")
# SeasonPitchingStats <- read_csv("pitching_individual.csv")
# ── 1. UI hardcoded strings ────────────────────────────────────────
ui_strings <- c(
# Page titles & tabs
"Baseball App", "Home Page", "Pitcher Statistics", "Batter Statistics",
"Application Information",
# Common labels
"Imperial", "Metric", "Filters", "Pitcher", "Batter",
"Pitcher Selection", "Batter Selection", "Pitcher Card", "Batter Card",
"League Standings", "Central League", "Pacific League",
"Team", "Wins", "Losses", "Ties", "Games Behind",
"Pitch Types", "Batter Hand", "Pitcher Hand",
"vs RHB", "vs LHB", "vs RHP", "vs LHP",
"All", "None",
# Stat leaders
"NPB Stat Leaders", "Stat Leaders", "Central League Stat Leaders", "Pacific League Stat Leaders",
"Batting Average", "Home Runs", "Runs Batted In", "Hits", "Stolen Bases",
"Earned Run Average", "Saves", "Strikeouts", "Innings Pitched",
# Card fields
"Age", "Height", "Weight", "Throws", "Bats", "Position",
"Right Handed", "Left Handed", "Switch Hitter",
"No bio info available", "No stats available",
"Season Pitching Stats", "Season Batting Stats",
# Plot/table headers
"Pitch Locations", "Pitch Type Breakdown",
"Pitch Type", "Pitch", "Usage %",
"Avg km/h", "Avg mph",
"AB", "H", "BA",
"Horizontal", "Height",
# Validate messages
"No pitches match.", "No data.", "Need at least 5 at-bats.",
# Page 4
"What is the purpose of this app?",
"Data in baseball has exponentially risen in the past quarter century. \n                          This app tackles the overwhelming masses of data by putting information into a concise, \n                          visual format.",
# Position groups
"Pitcher", "Catcher", "Infielder", "Outfielder",
# Team English short names
"BayStars", "Swallows", "Dragons", "Giants", "Carp", "Tigers",
"Buffaloes", "Hawks", "Marines", "Fighters", "Golden Eagles", "Lions"
)
# ── 2. Dynamic strings from data ───────────────────────────────────
pitch_types <- atbats %>%
filter(!is.na(ball_type)) %>%
pull(ball_type) %>% unique() %>% as.character()
team_names_jp <- unique(c(SeasonBattingStats$team, SeasonPitchingStats$team))
team_names_jp <- team_names_jp[!is.na(team_names_jp)]
position_groups <- unique(playerinfo$position_group_en)
position_groups <- position_groups[!is.na(position_groups)]
all_strings <- unique(c(ui_strings, pitch_types, team_names_jp, position_groups))
cat("Total unique strings:", length(all_strings), "\n")
# ── 3. Loop through every string × every language ──────────────────
languages <- c("en", "es", "ja", "zh", "ko")
total_calls <- length(all_strings) * length(languages)
cat("Total potential API calls:", total_calls, "\n")
cat("(Cached entries skip the API)\n\n")
count <- 0
start_time <- Sys.time()
for (lang in languages) {
cat("=== Warming", lang, "===\n")
for (s in all_strings) {
count <- count + 1
out <- translate(s, lang)
if (count %% 50 == 0) {
cat("  Processed", count, "/", total_calls,
"(", round(count/total_calls*100), "%)\n")
saveRDS(t_cache, CACHE_FILE)  # checkpoint every 50
}
Sys.sleep(0.05)  # tiny delay to be polite to Google's API
}
}
# Final save
saveRDS(t_cache, CACHE_FILE)
elapsed <- difftime(Sys.time(), start_time, units = "mins")
cat("\nDone! Cache size:", length(t_cache), "entries\n")
cat("Time:", round(as.numeric(elapsed), 1), "minutes\n")
cat("Cache file saved to:", CACHE_FILE, "\n")
runApp()
runApp()
shiny::runApp()
